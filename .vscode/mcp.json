{
  "servers": {
    "ntt-frida-mcp": {
      "type": "stdio",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "ntt_frida_mcp.server.main"]
    },
    "ntt-jadx-mcp": {
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "ntt_jadx_mcp.server.main"],
      "env": {
        "NTT_JADX_PORT": "8650"
      }
    }
  }
}
