{
  "servers": {
    "ntt-frida-mcp": {
      "type": "stdio",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "ntt_frida_mcp.server.main"]
    },
    "ntt-jadx-mcp": {
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "ntt_jadx_mcp.server.main"],
      "env": {
        "NTT_JADX_PORT": "8650"
      }
    },
    "ntt-objection-mcp": {
      "type": "stdio",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "ntt_objection_mcp.server.main"]
    },
    "ntt-adb-mcp": {
      "type": "stdio",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "ntt_adb_mcp.server.main"],
      "env": {
        "ADB_PATH": "C:\\AND\\platform-tools\\adb.exe"
      }
    }
  }
}
